<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Single exercise table: user_id NULL = built-in catalog; else user-owned. WorkoutSet references exercise.id. -->
    <changeSet id="012-exercise-table" author="brogres">
        <createTable tableName="exercise">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint"/>
            <column name="body_part" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="exercise" baseColumnNames="user_id"
                                 constraintName="fk_exercise_app_user"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <!-- PostgreSQL: partial unique indexes. H2 does not support WHERE on CREATE INDEX (see error_logs / H2 docs). -->
    <changeSet id="012-exercise-partial-unique" author="brogres" dbms="postgresql">
        <sql splitStatements="true" stripComments="true" endDelimiter=";">
            CREATE UNIQUE INDEX uk_exercise_catalog_body_name ON exercise (body_part, name) WHERE user_id IS NULL;
            CREATE UNIQUE INDEX uk_exercise_user_body_name ON exercise (user_id, body_part, name) WHERE user_id IS NOT NULL;
        </sql>
    </changeSet>

    <changeSet id="012-exercise-indexes-h2" author="brogres" dbms="h2">
        <comment>H2: no partial unique indexes — non-unique indexes for lookups only; uniqueness matches PostgreSQL in production.</comment>
        <createIndex indexName="idx_exercise_h2_body_part_name" tableName="exercise">
            <column name="body_part"/>
            <column name="name"/>
        </createIndex>
        <createIndex indexName="idx_exercise_h2_user_body_name" tableName="exercise">
            <column name="user_id"/>
            <column name="body_part"/>
            <column name="name"/>
        </createIndex>
    </changeSet>

    <changeSet id="012-exercise-seed-from-catalog" author="brogres">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="catalog_exercise"/>
        </preConditions>
        <sql dbms="h2,postgresql" splitStatements="true" stripComments="true" endDelimiter=";">
            INSERT INTO exercise (user_id, body_part, name, sort_order)
            SELECT NULL, body_part, name, sort_order FROM catalog_exercise;
        </sql>
    </changeSet>

    <changeSet id="012-exercise-seed-from-user-exercise" author="brogres">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="user_exercise"/>
        </preConditions>
        <sql dbms="h2,postgresql" splitStatements="true" stripComments="true" endDelimiter=";">
            INSERT INTO exercise (user_id, body_part, name, sort_order)
            SELECT user_id, body_part, name, 0 FROM user_exercise;
        </sql>
    </changeSet>

    <changeSet id="012-workout-set-exercise-id" author="brogres">
        <addColumn tableName="workout_set">
            <column name="exercise_id" type="bigint"/>
        </addColumn>
    </changeSet>

    <!-- Prefer user-owned row when both catalog and user match the same name. -->
    <changeSet id="012-workout-set-link-user-exercise" author="brogres">
        <sql dbms="h2,postgresql" splitStatements="true" stripComments="true" endDelimiter=";">
            UPDATE workout_set ws
            SET exercise_id = (
                SELECT e.id FROM exercise e
                INNER JOIN workout w ON w.id = ws.workout_id
                WHERE e.user_id = w.user_id AND e.body_part = ws.body_part AND e.name = ws.exercise
                LIMIT 1
            )
            WHERE ws.exercise_id IS NULL;
        </sql>
    </changeSet>

    <changeSet id="012-workout-set-link-catalog-exercise" author="brogres">
        <sql dbms="h2,postgresql" splitStatements="true" stripComments="true" endDelimiter=";">
            UPDATE workout_set ws
            SET exercise_id = (
                SELECT e.id FROM exercise e
                WHERE e.user_id IS NULL AND e.body_part = ws.body_part AND e.name = ws.exercise
                LIMIT 1
            )
            WHERE ws.exercise_id IS NULL;
        </sql>
    </changeSet>

    <changeSet id="012-exercise-insert-orphan-names" author="brogres">
        <sql dbms="h2,postgresql" splitStatements="true" stripComments="true" endDelimiter=";">
            INSERT INTO exercise (user_id, body_part, name, sort_order)
            SELECT DISTINCT w.user_id, ws.body_part, ws.exercise, 0
            FROM workout_set ws
            INNER JOIN workout w ON w.id = ws.workout_id
            WHERE ws.exercise_id IS NULL
              AND NOT EXISTS (
                SELECT 1 FROM exercise e
                WHERE e.user_id = w.user_id AND e.body_part = ws.body_part AND e.name = ws.exercise
              );
        </sql>
    </changeSet>

    <changeSet id="012-workout-set-link-after-orphan-insert" author="brogres">
        <sql dbms="h2,postgresql" splitStatements="true" stripComments="true" endDelimiter=";">
            UPDATE workout_set ws
            SET exercise_id = (
                SELECT e.id FROM exercise e
                INNER JOIN workout w ON w.id = ws.workout_id
                WHERE e.user_id = w.user_id AND e.body_part = ws.body_part AND e.name = ws.exercise
                LIMIT 1
            )
            WHERE ws.exercise_id IS NULL;
        </sql>
    </changeSet>

    <changeSet id="012-workout-set-exercise-id-not-null-fk" author="brogres">
        <addNotNullConstraint tableName="workout_set" columnName="exercise_id" columnDataType="bigint"/>
        <addForeignKeyConstraint baseTableName="workout_set" baseColumnNames="exercise_id"
                                 constraintName="fk_workout_set_exercise"
                                 referencedTableName="exercise" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="012-workout-set-drop-exercise-name" author="brogres">
        <dropColumn tableName="workout_set" columnName="exercise"/>
    </changeSet>

    <changeSet id="012-drop-catalog-exercise" author="brogres">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="catalog_exercise"/>
        </preConditions>
        <dropTable tableName="catalog_exercise"/>
    </changeSet>

    <changeSet id="012-drop-user-exercise" author="brogres">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="user_exercise"/>
        </preConditions>
        <dropTable tableName="user_exercise"/>
    </changeSet>

</databaseChangeLog>
