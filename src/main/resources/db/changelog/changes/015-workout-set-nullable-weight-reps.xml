<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- UI may save incomplete rows: weight and reps optional until filled in. -->
    <changeSet id="015-workout-set-nullable-weight-reps" author="brogres">
        <dropNotNullConstraint tableName="workout_set" columnName="weight" columnDataType="numeric(19, 2)"/>
        <dropNotNullConstraint tableName="workout_set" columnName="repetitions" columnDataType="integer"/>
    </changeSet>

</databaseChangeLog>
