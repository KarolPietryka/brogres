<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Drops the old one-day mega mock (changeSet id 003-mock-workout-2026-03-27) if it was already applied. -->
    <changeSet id="004-remove-legacy-mock-2026-03-27" author="brogres" context="dev">
        <sql dbms="h2,postgresql" splitStatements="true" stripComments="true" endDelimiter=";">
            DELETE FROM workout_set
            WHERE workout_id IN (SELECT id FROM workout WHERE workout_date = DATE '2026-03-27');
            DELETE FROM workout WHERE workout_date = DATE '2026-03-27';
        </sql>
    </changeSet>

</databaseChangeLog>
