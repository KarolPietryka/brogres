<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-add-planned-column" author="developer">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="workout_set" columnName="planned"/>
            </not>
        </preConditions>

        <addColumn tableName="workout_set">
            <column name="planned" type="boolean" defaultValueBoolean="false"/>
        </addColumn>

        <addNotNullConstraint tableName="workout_set"
                              columnName="planned"
                              defaultNullValue="false"/>
    </changeSet>

</databaseChangeLog>
