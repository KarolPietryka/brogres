<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="011-user-exercise-table" author="brogres">
        <createTable tableName="user_exercise">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="body_part" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="user_exercise" baseColumnNames="user_id"
                                 constraintName="fk_user_exercise_app_user"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
        <createIndex tableName="user_exercise" indexName="idx_user_exercise_user_body_part">
            <column name="user_id"/>
            <column name="body_part"/>
        </createIndex>
        <addUniqueConstraint tableName="user_exercise" columnNames="user_id, body_part, name"
                             constraintName="uk_user_exercise_user_body_name"/>
    </changeSet>

</databaseChangeLog>
